# =============================================================================
# 基础安全配置
# =============================================================================

# 必填：Django 密钥，生产环境务必修改为随机、安全的长字符串
SECRET_KEY=change-me

# 必填：是否开启调试模式；开发环境可为 True，生产必须为 False
DEBUG=True

# 必填：允许访问的域名/IP，逗号分隔且不含空格
ALLOWED_HOSTS=localhost,127.0.0.1


# =============================================================================
# 数据库配置
# =============================================================================

# 必填：数据库引擎（需要完整后端路径）
# 可选值：
#   - django.db.backends.sqlite3
#   - django.db.backends.postgresql
#   - django.db.backends.mysql
DB_ENGINE=django.db.backends.sqlite3

# 必填：数据库名
# - 使用 sqlite3 时：填写 sqlite 文件名，例如 db.sqlite3（需要完整后端路径）
# - 使用其他数据库时：填写数据库名，例如 ftc
DB_NAME=db.sqlite3

# 使用 django 自带数据库 sqlite3 时不需要以下配置，使用其他数据库时请根据实际情况填写

# 可选：数据库用户名
# DB_USER=

# 可选：数据库密码
# DB_PASSWORD=

# 可选：数据库主机（例如 127.0.0.1）
# DB_HOST=

# 可选：数据库端口（MySQL 默认 3306，PostgreSQL 默认 5432）
# DB_PORT=


# =============================================================================
# Redis 配置（缓存 / 限流 / 排行榜等）
# =============================================================================

# 必填：Redis 地址
REDIS_HOST=127.0.0.1

# 必填：Redis 端口
REDIS_PORT=6379

# 必填：缓存所用 DB 编号（推荐使用 0）
REDIS_DB_CACHE=0

# 可选：Redis 密码（无密码则保持注释或留空）
# REDIS_PASSWORD=

# 可选：是否使用内存 mock
# - 1：不连接真实 Redis，仅用于开发调试
# - 0：连接真实 Redis（生产环境必须为 0 或保持注释）
# REDIS_USE_MOCK=0


# =============================================================================
# Docker 配置（靶机容器管理）
# =============================================================================

# 可选：Docker 主机地址
# - 留空：使用本机默认 socket（开发 / 单机部署推荐）
# - 示例：tcp://10.0.0.1:2375
# DOCKER_HOST=

# 可选：远程 Docker TLS 校验开关；使用 TLS 时设为 1
# DOCKER_TLS_VERIFY=0

# 可选：TLS 证书目录（包含 ca.pem / cert.pem / key.pem）
# DOCKER_CERT_PATH=/path/to/certs

# 可选：是否启用 Docker mock
# - 1：不实际创建容器，仅返回假容器 ID（用于无 Docker 环境调试）
# - 0：正常调用 Docker
# DOCKER_USE_MOCK=0

# 可选：镜像前缀，例如 registry.local/ftc/
#DOCKER_IMAGE_PREFIX=

# 必填：镜像标签，默认 latest；如需固定版本可修改
DOCKER_IMAGE_TAG=latest

# 必填：容器内服务端口；默认 80（HTTP 服务）
DOCKER_CONTAINER_PORT=80

# 可选：Docker 网络名称；留空时使用默认网络
# DOCKER_NETWORK=


# =============================================================================
# 邮件配置
# =============================================================================

# 必填：邮件服务提供商；用于自动填充 host/port/SSL 配置
# 可选值：qq / 163 / gmail / outlook
EMAIL_PROVIDER=qq

# 可选：覆盖默认 SMTP 服务器地址（通常可留空，使用 provider 默认值）
# EMAIL_HOST=

# 可选：覆盖默认 SMTP 端口（通常可留空，使用 provider 默认值）
# EMAIL_PORT=

# 可选：覆盖默认 TLS/SSL 配置（通常可留空，使用 provider 默认值）
# EMAIL_USE_TLS=
# EMAIL_USE_SSL=

# 必填：发信邮箱账号，例如 no-reply@example.com 或 your_name@qq.com
EMAIL_HOST_USER=your_account@qq.com

# 必填：发信邮箱授权码或应用专用密码（不是登录密码!）
EMAIL_HOST_PASSWORD=your_smtp_password_here

# 必填：对外展示的默认发件人，例如 "FindTheCat 组委会 <no-reply@example.com>"
DEFAULT_FROM_EMAIL=FindTheCat 组委会 <your_account@qq.com>

# 可选：邮件 backend
# - 生产环境：保持默认（SMTP）
# - 开发环境：可改为 django.core.mail.backends.console.EmailBackend 仅打印邮件
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
