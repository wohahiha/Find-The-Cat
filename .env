# Environment variables for Django project

# 安全配置
# SECRET_KEY：Django 密钥，线上务必替换为随机安全值
SECRET_KEY=my-very-secret-key
# DEBUG：开发环境 True，线上必须 False
DEBUG=True
# ALLOWED_HOSTS：允许访问域名/IP，逗号分隔且不含空格
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库配置
# DB_ENGINE：django.db.backends.sqlite3 / mysql / postgresql
DB_ENGINE=django.db.backends.sqlite3
# DB_NAME：数据库名（或 sqlite3 文件名）
DB_NAME=db.sqlite3
# DB_USER：数据库用户名（sqlite3 可留空）
DB_USER=
# DB_PASSWORD：数据库密码
DB_PASSWORD=
# DB_HOST：数据库主机（如 127.0.0.1）
DB_HOST=
# DB_PORT：数据库端口（mysql 默认 3306，postgres 默认 5432）
DB_PORT=

# 邮件配置（未在后台配置发信账号时的默认配置）
# EMAIL_PROVIDER：qq / 163 / gmail / outlook，留空表示自定义 SMTP
EMAIL_PROVIDER=
# EMAIL_HOST：SMTP 服务器地址（使用 provider 时可留空）
EMAIL_HOST=
# EMAIL_PORT：SMTP 端口（provider 默认值不满足时填写）
EMAIL_PORT=
# EMAIL_USE_TLS：是否启用 TLS（True/False）
EMAIL_USE_TLS=
# EMAIL_USE_SSL：是否启用 SSL（True/False，与 TLS 二选一）
EMAIL_USE_SSL=
# EMAIL_HOST_USER：发信邮箱账号，例如 no-reply@example.com
EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD：发信邮箱授权码或应用专用密码
EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL：对外展示的发信人，例如 "FindTheCat 组委会 <no-reply@example.com>"
DEFAULT_FROM_EMAIL=
